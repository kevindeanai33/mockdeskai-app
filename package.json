{
  "name": "mockdeskai-app",
  "version": "0.1.0",
  "description": "MockDeskAI — AI-powered PSD design proofing",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "dev:server": "node server/index.js",
    "dev": "concurrently -n electron,vite \"electron .\" \"vite\"",
    "build": "vite build && electron-builder",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "vite build && electron-builder"
  },
  "author": "Kevin Dean",
  "license": "UNLICENSED",
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.4",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "ag-psd": "^30.1.0",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.mockdeskai.app",
    "productName": "MockDeskAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": ["dmg"],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    }
  }
}
